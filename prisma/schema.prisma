generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model games {
  id         Int        @id @default(autoincrement())
  slug       String     @unique(map: "slug") @db.VarChar(255)
  name       String     @db.VarChar(255)
  publisher  String     @db.VarChar(255)
  category   String     @db.VarChar(255)
  badge      String?    @default("Instant") @db.VarChar(255)
  image_url  String?    @db.VarChar(255)
  created_at DateTime   @default(now()) @db.DateTime(0)
  updated_at DateTime   @default(now()) @db.DateTime(0)
  nominals   nominals[]

  @@index([slug], map: "games_slug")
}

model nominals {
  id         Int      @id @default(autoincrement())
  game_id    Int
  label      String   @db.VarChar(255)
  amount     Int      @default(0)
  price      Int
  bonus      String?  @db.VarChar(255)
  sku_code   String?  @db.VarChar(100)
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @db.DateTime(0)
  games      games    @relation(fields: [game_id], references: [id], onDelete: Cascade, map: "nominals_ibfk_1")

  @@index([game_id], map: "nominals_game_id")
}

model sequelizemeta {
  name String @id @unique(map: "name") @db.VarChar(255)
}

model users {
  id         Int      @id @default(autoincrement())
  email      String   @unique(map: "email") @db.VarChar(255)
  password   String   @db.VarChar(255)
  name       String   @db.VarChar(255)
  role       String   @default("user") @db.VarChar(50)
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @db.DateTime(0)

  @@index([email], map: "users_email")
}

model orders {
  id              Int      @id @default(autoincrement())
  order_code      String   @unique @db.VarChar(64)
  user_id         Int?
  player_id       String   @db.VarChar(100)
  server_id       String?  @db.VarChar(100)
  nickname        String   @db.VarChar(100)
  game_slug       String   @db.VarChar(255)
  game_name       String   @db.VarChar(255)
  game_image      String?  @db.VarChar(500)
  item_label      String   @db.VarChar(255)
  item_price      Int
  payment_method  String?  @db.VarChar(100)
  xendit_invoice_id  String?  @db.VarChar(255)
  xendit_invoice_url String?  @db.VarChar(500)
  digiflazz_ref      String?  @db.VarChar(100)
  digiflazz_status   String?  @db.VarChar(50)
  vip_reseller_ref   String?  @db.VarChar(100)
  vip_reseller_status String? @db.VarChar(50)
  service_code       String?  @db.VarChar(100)
  status             String   @default("pending") @db.VarChar(50)
  processed_at       DateTime?
  created_at      DateTime @default(now()) @db.DateTime(0)
  updated_at      DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_id], map: "orders_user_id")
  @@index([order_code], map: "orders_order_code")
  @@index([status], map: "orders_status")
}

model refresh_tokens {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique(map: "token") @db.VarChar(255)
  expires_at DateTime @db.DateTime(0)
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @db.DateTime(0)

  @@index([user_id], map: "refresh_tokens_user_id")
  @@index([token], map: "refresh_tokens_token")
}

model game_player_cache {
  id         Int      @id @default(autoincrement())
  game_slug  String   @db.VarChar(100)
  user_id    String   @db.VarChar(100)
  server_id  String?  @db.VarChar(100)
  nickname   String   @db.VarChar(100)
  // Region fields from VIP Reseller
  region_code   String?  @db.VarChar(50)   // e.g., "ID", "SG", "BR"
  region_name   String?  @db.VarChar(100)  // e.g., "Indonesia", "Singapore"
  region_zone   String?  @db.VarChar(50)   // zone/area code
  country       String?  @db.VarChar(100)   // country name
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([game_slug, user_id, server_id], map: "game_user_server_unique")
  @@index([game_slug], map: "cache_game_slug")
  @@index([user_id], map: "cache_user_id")
  @@index([region_code], map: "cache_region_code")
}

model vip_services {
  id           Int      @id @default(autoincrement())
  game_slug    String   @db.VarChar(100)
  service_code String   @db.VarChar(100)
  name         String   @db.VarChar(255)
  price        Int      // VIP price (our selling price)
  normal_price Int      @default(0) // Original price for strikethrough
  basic        Int?
  premium      Int?
  special      Int?
  updated_at   DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([game_slug, service_code], map: "game_service_unique")
  @@index([game_slug], map: "vip_game_slug")
}

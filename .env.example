# ============================================
# GameHub Frontend - Environment Variables
# ============================================
# Copy file ini ke .env.local dan sesuaikan nilainya
# cp .env.example .env.local

# Backend API URL (wajib)
# Untuk development lokal, sesuaikan dengan IP/port backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public Site URL (opsional, direkomendasikan)
# URL frontend yang stabil untuk redirect setelah pembayaran Xendit
# Jika tidak di-set, akan menggunakan window.location.origin (bisa berubah jika IP berubah)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
